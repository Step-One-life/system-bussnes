# Server
NODE_ENV=development
PORT=3021

# Database — MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=trikick
DB_PASSWORD=trikick
DB_NAME=trikick

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# CORS — frontend origin
CORS_ORIGIN=http://localhost:3020

# Google Calendar (опционально) — без этих переменных синхронизация просто
# неактивна, приложение работает как обычно. Настройка — см. README §Синхронизация.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3021/api/calendar/google/callback
# Ключ шифрования refresh-токенов (обязателен при NODE_ENV=production, если синк включён):
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CALENDAR_TOKEN_ENC_KEY=
