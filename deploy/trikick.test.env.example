# TEST env для docker-compose.test.yml.
# Скопировать в trikick.test.env, заполнить, НЕ коммитить (см. .gitignore).

# MySQL — изолированная БД в контейнере trikick-test-db
DB_ROOT_PASSWORD=change-me-root
DB_NAME=trikick
DB_USER=trikick
DB_PASSWORD=change-me-db

# JWT
JWT_SECRET=change-me-test-secret
JWT_EXPIRES_IN=7d

# CORS — домен тестового фронта
CORS_ORIGIN=https://trick.ozma-split.com

# Шифрование refresh-токенов Google Calendar.
# Сгенерируй: openssl rand -base64 48. ВАЖНО: если потеряете ключ,
# все сохранённые OAuth-токены станут нерасшифровываемыми.
CALENDAR_TOKEN_ENC_KEY=

# Google OAuth для интеграции календаря.
# Получить в Google Cloud Console → APIs & Services → Credentials.
# Включить Google Calendar API в Library.
# В Authorized redirect URIs добавить: https://<домен>/api/calendar/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
